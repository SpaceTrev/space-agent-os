# ================================================================
# Agent OS — Environment Variables
# Copy this file to .env.local and fill in values
# ================================================================

# ----------------------------------------------------------------
# MUST HAVE TO RUN LOCALLY
# Get from: https://supabase.com/dashboard → Project Settings → API
# ----------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Auth secret for cookie signing (run: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Encryption key for storing API keys in DB (run: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-key

# ----------------------------------------------------------------
# MUST HAVE FOR CORE FEATURES
# ----------------------------------------------------------------

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — https://dashboard.stripe.com/products
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_...

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------
# OPTIONAL — AI PROVIDER API KEYS
# These are fallback defaults. Workspace-level keys override these.
# ----------------------------------------------------------------

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Mistral — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Perplexity — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# ----------------------------------------------------------------
# OPTIONAL — COMPUTE PROVIDERS
# ----------------------------------------------------------------

# Railway — https://railway.app/account/tokens
RAILWAY_TOKEN=

# Fly.io — https://fly.io/user/personal_access_tokens
FLY_API_TOKEN=

# ----------------------------------------------------------------
# OPTIONAL — INTEGRATIONS
# ----------------------------------------------------------------

# Discord bot — https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Linear — https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...
LINEAR_WEBHOOK_SECRET=

# GitHub — https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ----------------------------------------------------------------
# QUEUE CONFIG
# ----------------------------------------------------------------

MAX_CONCURRENT_TASKS=3
