# Space-Claw — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Anthropic (Architect Tier) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail MCP ─────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Slack MCP ─────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ── WhatsApp / Twilio ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+1...

# ── Discord (primary control channel) ─────────────────────────────────────
# 1. discord.com/developers → New Application → Bot → Reset Token
DISCORD_BOT_TOKEN=MTQ4NDc5MjQ1ODk4MTQxMjg5NA.Ghar3Z.twLaFZ9hM8o-
# 2. Discord: Server Settings → right-click server icon → Copy Server ID (enable dev mode first)
DISCORD_GUILD_ID=1484790691077947402
# 3. Right-click the channel you want the bot to post in → Copy Channel ID (optional)
DISCORD_CHANNEL_ID=1484793801531719803

# ── Tailscale ──────────────────────────────────────────────────────────
TAILSCALE_IP=100.102.161.30

# Comma-separated allowlist of IPs allowed to reach the WS/control APIs.
# Supports exact IPs and CIDR ranges. Leave blank = open (local dev only).
# Your Tailscale subnet is typically 100.64.0.0/10 — add specific device IPs
# e.g.: ALLOWED_IPS=100.102.161.30,100.x.y.z,127.0.0.1
ALLOWED_IPS=100.102.161.30,127.0.0.1

# ── Ollama (Defaults — override if needed) ──────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
ORCHESTRATOR_MODEL=llama3.3:8b
WORKER_MODEL=qwen3-coder:30b-a3b

# ── Heartbeat ─────────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL=1800   # seconds (30 min)

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
