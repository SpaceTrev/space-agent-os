# Space-Claw — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Gemini (Cloud Tier) ────────────────────────────────────────────────────
# From Google AI Studio: aistudio.google.com → Get API key
GEMINI_API_KEY=

# ── OpenClaw (Primary Tier — Claude Max) ──────────────────────────────────
OPENCLAW_API_KEY=

# ── Anthropic (fallback — if not using OpenClaw) ──────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail MCP ─────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Slack MCP ─────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# ── Discord (primary control channel) ─────────────────────────────────────
# 1. discord.com/developers → New Application → Bot → Reset Token
DISCORD_TOKEN=
# Alias (legacy) — DISCORD_TOKEN takes precedence if both are set
DISCORD_BOT_TOKEN=
# 2. Discord: Server Settings → right-click server icon → Copy Server ID (enable dev mode first)
DISCORD_GUILD_ID=
# 3. Right-click the channel you want the bot to post in → Copy Channel ID
DISCORD_CHANNEL_ID=

# ── Tailscale ──────────────────────────────────────────────────────────
TAILSCALE_IP=100.102.161.30

# Comma-separated allowlist of IPs allowed to reach the WS/control APIs.
# Supports exact IPs and CIDR ranges. Leave blank = open (local dev only).
# Your Tailscale subnet is typically 100.64.0.0/10 — add specific device IPs
# e.g.: ALLOWED_IPS=100.102.161.30,100.x.y.z,127.0.0.1
ALLOWED_IPS=100.102.161.30,127.0.0.1

# ── Model Selection ───────────────────────────────────────────────────────
PRIMARY_MODEL=claude-sonnet-4-6
SECONDARY_MODEL=gemini/gemini-2.0-flash
WORKER_MODEL=qwen3-coder:30b

# ── Ollama (optional — disabled by default) ───────────────────────────────
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# ── Heartbeat ─────────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL=1800   # seconds (30 min)

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
