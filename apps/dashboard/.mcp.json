{
  "mcpServers": {
    "agent-os": {
      "command": "npx",
      "args": ["tsx", "mcp/server.ts"],
      "cwd": ".",
      "env": {
        "SUPABASE_URL": "${SUPABASE_URL}",
        "SUPABASE_SERVICE_KEY": "${SUPABASE_SERVICE_KEY}",
        "AGENT_OS_URL": "http://localhost:3000"
      }
    },
    "railway": {
      "command": "npx",
      "args": ["-y", "@railway/mcp-server"],
      "env": {
        "RAILWAY_API_TOKEN": "${RAILWAY_API_TOKEN}"
      }
    }
  }
}
